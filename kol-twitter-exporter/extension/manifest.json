{
  "manifest_version": 3,
  "name": "KOL Signal 导出器",
  "version": "2.6",
  "description": "抓取X(Twitter) KOL主页推文，按月导出为Obsidian风格Markdown",
  "permissions": [],
  "content_scripts": [{
    "matches": ["*://twitter.com/*", "*://x.com/*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }],
  "icons": {
    "128": "icon.png"
  }
}
